# PARKED — NOT active.
#
# This workflow is the release-automation template for python-docx,
# but the fork deliberately has no `.github/` directory (removed in
# commit 2aa5e4c on 2026-05-02; see
# `~/.claude/projects/-home-ben-code-python-docx/memory/ci_current.md`
# for the session-level rationale). Dropping this file into
# `.github/workflows/` would re-introduce CI without explicit
# maintainer consent.
#
# To activate:
#   1. Confirm with the maintainer that resuming GitHub Actions is
#      wanted for this repository.
#   2. `mkdir -p .github/workflows`
#   3. `git mv scripts/release/release.yml.parked .github/workflows/release.yml`
#   4. Configure PyPI trusted publishing — on pypi.org the project
#      needs a "pending publisher" entry matching
#        owner:        loadfix
#        repository:   python-docx
#        workflow:     release.yml
#        environment:  pypi
#      (see https://docs.pypi.org/trusted-publishers/ — no API
#      tokens are needed, the workflow authenticates via OIDC).
#   5. Push a tag of the shape ``v2026.05.7`` (matching
#      ``__version__`` after ``scripts/prepare_release.py``) and the
#      workflow will build an sdist + wheel and publish to PyPI.
#
# Scope deliberately narrow: this does *only* build + publish. Tests
# are assumed to have been run locally by
# ``scripts/prepare_release.py`` before the tag was pushed.

name: release

"on":
  push:
    tags:
      - "v[0-9]+.[0-9]+.[0-9]+"

# Only one release run per tag. A retry of the same tag should
# replace the in-flight publish, not race it.
concurrency:
  group: release-${{ github.ref }}
  cancel-in-progress: false

jobs:
  build:
    name: Build sdist + wheel
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0  # so setuptools-scm / tag metadata is intact

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"
          cache: pip

      - name: Install build tooling
        run: |
          python -m pip install --upgrade pip
          python -m pip install build

      - name: Build sdist and wheel
        run: python -m build

      - name: Upload dist artifact
        uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/
          if-no-files-found: error

  publish-pypi:
    name: Publish to PyPI via trusted publishing
    needs: build
    runs-on: ubuntu-latest
    # The `pypi` environment must be configured on GitHub with the
    # same name; it gates the OIDC trust relationship registered on
    # pypi.org.
    environment:
      name: pypi
      url: https://pypi.org/p/python-docx
    permissions:
      # OIDC: the runner requests a short-lived token, PyPI verifies
      # it against the trusted-publisher registration. No stored
      # secrets.
      id-token: write
    steps:
      - name: Download dist artifact
        uses: actions/download-artifact@v4
        with:
          name: dist
          path: dist/

      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1
        with:
          # No `password:` — trusted publishing is used.
          skip-existing: true
